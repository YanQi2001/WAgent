# ── LLM 供应商配置 ──
# WAgent 兼容所有 OpenAI 格式的 API。
# 取消注释下方任意一个供应商配置块，填入你的 API key 即可。

# --- DeepSeek（推荐，中文效果好，价格便宜） ---
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- MiniMax ---
# LLM_API_KEY=your-minimax-key
# LLM_BASE_URL=https://api.minimax.chat/v1
# LLM_MODEL=MiniMax-Text-01

# --- OpenAI ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- NVIDIA Inference API ---
# LLM_API_KEY=your-nvidia-key
# LLM_BASE_URL=https://inference-api.nvidia.com/v1
# LLM_MODEL=gcp/google/gemini-3-pro

# --- Moonshot（Kimi） ---
# LLM_API_KEY=your-moonshot-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-auto

# ── Fast tier（可选，用于降低简单任务成本） ──
# 配置后，意图分类、元数据生成等简单任务将走此模型，节省 token 费用。
# 未配置则所有任务统一走上方的主模型。
# LLM_FAST_API_KEY=your-siliconflow-key
# LLM_FAST_BASE_URL=https://api.siliconflow.cn/v1
# LLM_FAST_MODEL=deepseek-ai/DeepSeek-V3

# ── 通用设置 ──
TOKEN_BUDGET=100000
QDRANT_PATH=./data/qdrant_db
KNOWLEDGE_UPDATE_INTERVAL=43200

# Qdrant Server 模式（Docker，可选；留空则使用本地文件模式）
# QDRANT_URL=http://localhost:6333
